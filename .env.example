# Copy this file to .env and fill in your values for local development.
# In production, set these in: Netlify → Site Settings → Environment Variables

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Resend — resend.com → API Keys
RESEND_API_KEY=re_your_key_here

# Meta (Facebook / Instagram) — developers.facebook.com → App → Webhooks
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here
META_VERIFY_TOKEN=any_random_string_you_choose
META_ACCESS_TOKEN=your_page_access_token_here
